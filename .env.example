# Discord
DISCORD_PUBLIC_KEY_HEX=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# OpenAI mention assistant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Jellyfin
JELLYFIN_URL=http://jellyfin:8096
# Or use host/port instead of URL:
# JELLYFIN_HOST=host.docker.internal
# JELLYFIN_PORT=8096
JELLYFIN_API_KEY=
JELLYFIN_WEBHOOK_TOKEN=
JELLYREAPER_SHARED_NETWORK=media_shared

# Runtime
HTTP_PORT=6767
HTTP_ADDR=:6767
DB_PATH=/data/jellyreaper.db
LOG_DIR=/logs
EMBED_PERSIST_DIR=/embeds
LEASE_TTL=30s
WORKER_ID=jellyreaper-1
DEFAULT_DELAY_WINDOW=15d
DEFAULT_LAST_PLAYED_THRESHOLD_DAYS=60

# Backfill / reconciliation
BACKFILL_ENABLED=true
BACKFILL_INTERVAL=15m
BACKFILL_FULL_SWEEP_ON_STARTUP=true
BACKFILL_PLAYBACK_ENABLED=false
BACKFILL_LOOKBACK=24h
BACKFILL_OVERLAP=2m
BACKFILL_LIMIT=500
BACKFILL_WRITE_BATCH_SIZE=100
BACKFILL_WRITE_BATCH_TIMEOUT=500ms
BACKFILL_WRITE_QUEUE_CAPACITY=2000
